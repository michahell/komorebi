{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "vitest": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@djankies/vitest-mcp"],
      "env": {}
    },
    "taiga-ui": {
      "command": "npx",
      "args": ["@taiga-ui/mcp@v0.1.0-alpha.16"]
    }
  }
}
